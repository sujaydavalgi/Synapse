{
  "name": "@spanda/native",
  "version": "0.4.0",
  "description": "Spanda Rust core bindings for Node.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Davalgi/Spanda.git",
    "directory": "packages/native"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:native": "napi build --platform --release --cargo-cwd ../../crates/spanda-node --js ./native.js --dts ./native.d.ts .",
    "build:cli": "cargo build -p spanda-cli --release"
  },
  "napi": {
    "name": "spanda-node",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu"
      ]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "typescript": "^5.7.0"
  }
}
