{
  "openapi": "3.1.0",
  "info": {
    "title": "Spanda Control Center API",
    "version": "1.0.0",
    "description": "REST v1 gateway for enterprise operations — device pool, provisioning, drift, OTA, trust, SRE."
  },
  "servers": [{ "url": "http://127.0.0.1:8080" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "SPANDA_API_KEY value"
      }
    },
    "parameters": {
      "correlationId": {
        "name": "X-Correlation-ID",
        "in": "header",
        "schema": { "type": "string" },
        "description": "Optional request correlation ID; echoed in response"
      }
    }
  },
  "paths": {
    "/v1/health": {
      "get": {
        "summary": "Liveness",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/tenant": {
      "get": {
        "summary": "Active Control Center tenant (SPANDA_TENANT_ID)",
        "responses": { "200": { "description": "Tenant scope metadata" } }
      }
    },
    "/v1/version": {
      "get": {
        "summary": "API versioning policy",
        "responses": { "200": { "description": "Supported API versions" } }
      }
    },
    "/v1/dashboard": {
      "get": {
        "summary": "Operations dashboard summary",
        "responses": { "200": { "description": "Device pool and alert counts" } }
      }
    },
    "/v1/devices": {
      "get": {
        "summary": "List devices in the device pool",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Device inventory" } }
      }
    },
    "/v1/devices/discover": {
      "post": {
        "summary": "Run multi-transport device discovery",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "transports": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Discovery results" } }
      }
    },
    "/v1/devices/{id}": {
      "get": {
        "summary": "Get device by id",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Device record" }, "404": { "description": "Not found" } }
      }
    },
    "/v1/devices/{id}/provision": {
      "post": {
        "summary": "Provision a discovered device",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Provision result" } }
      }
    },
    "/v1/devices/{id}/assign": {
      "post": {
        "summary": "Assign device to robot or fleet",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Assignment result" } }
      }
    },
    "/v1/devices/{id}/quarantine": {
      "post": {
        "summary": "Quarantine a device",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Quarantine result" } }
      }
    },
    "/v1/devices/{id}/trust": {
      "post": {
        "summary": "Trust / approve a device after operator review",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Trust result" } }
      }
    },
    "/v1/robots": {
      "get": {
        "summary": "List robots with assigned devices",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Robot inventory" } }
      }
    },
    "/v1/fleets": {
      "get": {
        "summary": "List fleets",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Fleet inventory" } }
      }
    },
    "/v1/device-tree": {
      "get": {
        "summary": "Hierarchical device tree",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Device tree" } }
      }
    },
    "/v1/device-reports": {
      "get": {
        "summary": "Device pool reports bundle",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Inventory, trust, calibration, readiness reports" } }
      }
    },
    "/v1/failover/chains": {
      "get": {
        "summary": "Redundant device failover chains",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Failover chain definitions" } }
      }
    },
    "/v1/readiness/run": {
      "post": {
        "summary": "Run readiness checks with device pool impact",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Readiness report" } }
      }
    },
    "/v1/drift": {
      "get": {
        "summary": "Operational drift report",
        "parameters": [
          {
            "name": "baseline_id",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Drift rollup across 7 dimensions" } }
      }
    },
    "/v1/ota/plan": {
      "post": {
        "summary": "Plan OTA rollout (canary, staged, blue_green)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "strategy": { "type": "string", "enum": ["all", "canary", "staged", "blue_green"] },
                  "version": { "type": "string" },
                  "canary_percent": { "type": "integer" },
                  "dry_run": { "type": "boolean" },
                  "assignments": { "type": "array", "items": { "type": "object" } }
                },
                "required": ["strategy", "version"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Rollout plan" } }
      }
    },
    "/v1/ota/execute": {
      "post": {
        "summary": "Execute OTA rollout against deploy agents (dry_run supported)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "strategy": { "type": "string", "enum": ["all", "canary", "staged", "blue_green"] },
                  "version": { "type": "string" },
                  "canary_percent": { "type": "integer" },
                  "dry_run": { "type": "boolean" },
                  "assignments": { "type": "array", "items": { "type": "object" } }
                },
                "required": ["strategy", "version"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Rollout result" } }
      }
    },
    "/v1/ota/status": {
      "get": {
        "summary": "Deploy state from .spanda/deploy-state.json",
        "responses": { "200": { "description": "OTA state" } }
      }
    },
    "/v1/trust/package": {
      "get": {
        "summary": "Package trust evaluation",
        "parameters": [
          { "name": "name", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "version", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Trust score report" } }
      }
    },
    "/v1/sre/summary": {
      "get": {
        "summary": "SRE availability and alert rollup",
        "responses": { "200": { "description": "SRE metrics" } }
      }
    },
    "/v1/observability/traces": {
      "get": {
        "summary": "Recent API trace records (OTLP-compatible export path)",
        "responses": { "200": { "description": "Trace log" } }
      }
    },
    "/v1/observability/backend": {
      "get": {
        "summary": "Configured OTLP collector endpoints (SPANDA_OTEL_COLLECTOR_URL)",
        "responses": { "200": { "description": "Observability backend summary" } }
      }
    },
    "/v1/observability/otlp/metrics": {
      "get": {
        "summary": "OTLP/JSON metrics preview",
        "responses": { "200": { "description": "resourceMetrics payload" } }
      }
    },
    "/v1/audit/mutations": {
      "get": {
        "summary": "Mutation audit trail",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Hash-chained mutation records" } }
      }
    },
    "/v1/operator/quarantine": {
      "post": {
        "summary": "Quarantine a device",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Device quarantined" } }
      }
    },
    "/v1/operator/mission/approve": {
      "post": {
        "summary": "Approve or reject a mission",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Mission decision recorded" } }
      }
    },
    "/v1/rpc": {
      "post": {
        "summary": "gRPC-compatible JSON gateway",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "method": { "type": "string" },
                  "params": { "type": "object" }
                },
                "required": ["method"]
              }
            }
          }
        },
        "responses": { "200": { "description": "RPC result" } }
      }
    }
  }
}
