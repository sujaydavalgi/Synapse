{
  "openapi": "3.1.0",
  "info": {
    "title": "Spanda Control Center API",
    "version": "1.0.0",
    "description": "REST v1 gateway for enterprise operations — device pool, provisioning, drift, OTA, trust, SRE."
  },
  "servers": [{ "url": "http://127.0.0.1:8080" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "SPANDA_API_KEY value"
      }
    },
    "parameters": {
      "correlationId": {
        "name": "X-Correlation-ID",
        "in": "header",
        "schema": { "type": "string" },
        "description": "Optional request correlation ID; echoed in response"
      }
    }
  },
  "paths": {
    "/v1/health": {
      "get": {
        "summary": "Liveness",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/tenant": {
      "get": {
        "summary": "Active Control Center tenant (SPANDA_TENANT_ID)",
        "responses": { "200": { "description": "Tenant scope metadata" } }
      }
    },
    "/v1/version": {
      "get": {
        "summary": "API versioning policy",
        "responses": { "200": { "description": "Supported API versions" } }
      }
    },
    "/v1/openapi.json": {
      "get": {
        "summary": "OpenAPI 3.1 specification for this API",
        "responses": { "200": { "description": "OpenAPI document" } }
      }
    },
    "/v1/dashboard": {
      "get": {
        "summary": "Operations dashboard summary",
        "responses": { "200": { "description": "Device pool and alert counts" } }
      }
    },
    "/v1/devices": {
      "get": {
        "summary": "List devices in the device pool",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Device inventory" } }
      }
    },
    "/v1/devices/discover": {
      "post": {
        "summary": "Run multi-transport device discovery",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "transports": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Discovery results" } }
      }
    },
    "/v1/devices/{id}": {
      "get": {
        "summary": "Get device by id",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Device record" }, "404": { "description": "Not found" } }
      },
      "patch": {
        "summary": "Update device lifecycle_state",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "lifecycle_state": { "type": "string" } },
                "required": ["lifecycle_state"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Device updated" } }
      }
    },
    "/v1/devices/{id}/provision": {
      "post": {
        "summary": "Provision a discovered device",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Provision result" } }
      }
    },
    "/v1/devices/{id}/assign": {
      "post": {
        "summary": "Assign device to robot or fleet",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Assignment result" } }
      }
    },
    "/v1/devices/{id}/quarantine": {
      "post": {
        "summary": "Quarantine a device",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Quarantine result" } }
      }
    },
    "/v1/devices/{id}/trust": {
      "post": {
        "summary": "Trust / approve a device after operator review",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Trust result" } }
      }
    },
    "/v1/robots": {
      "get": {
        "summary": "List robots with assigned devices",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Robot inventory" } }
      }
    },
    "/v1/fleets": {
      "get": {
        "summary": "List fleets",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Fleet inventory" } }
      }
    },
    "/v1/device-tree": {
      "get": {
        "summary": "Hierarchical device tree",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Device tree" } }
      }
    },
    "/v1/device-reports": {
      "get": {
        "summary": "Device pool reports bundle",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Inventory, trust, calibration, readiness reports" } }
      }
    },
    "/v1/failover/chains": {
      "get": {
        "summary": "Redundant device failover chains",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Failover chain definitions" } }
      }
    },
    "/v1/fleet/agents": {
      "get": {
        "summary": "Registered fleet agents",
        "responses": { "200": { "description": "Fleet agent registry" } }
      }
    },
    "/v1/alerts": {
      "get": {
        "summary": "Alert history",
        "responses": { "200": { "description": "Alert list" } }
      }
    },
    "/v1/alerts/test": {
      "post": {
        "summary": "Dispatch test alert",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Test alert recorded" } }
      }
    },
    "/v1/secrets": {
      "get": {
        "summary": "Secret metadata (no values)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Secret metadata list" } }
      }
    },
    "/v1/rbac/matrix": {
      "get": {
        "summary": "Role permission matrix",
        "responses": { "200": { "description": "RBAC matrix" } }
      }
    },
    "/v1/provision": {
      "post": {
        "summary": "Run discover → ready provisioning workflow",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Provision result" } }
      }
    },
    "/v1/config/snapshots": {
      "get": {
        "summary": "List configuration snapshots",
        "responses": { "200": { "description": "Snapshot metadata" } }
      },
      "post": {
        "summary": "Save configuration snapshot",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "label": { "type": "string" },
                  "encrypt": {
                    "type": "boolean",
                    "description": "AES-256-GCM at rest (requires SPANDA_CONFIG_SNAPSHOT_KEY or SPANDA_CONFIG_SNAPSHOT_ENCRYPT=1)"
                  }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Snapshot saved" } }
      }
    },
    "/v1/discovery": {
      "get": {
        "summary": "Package-backed device discovery",
        "parameters": [
          { "name": "transport", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Discovery matches" } }
      }
    },
    "/v1/health/summary": {
      "get": {
        "summary": "Device pool health rollup",
        "responses": { "200": { "description": "Health summary" } }
      }
    },
    "/v1/assurance/summary": {
      "get": {
        "summary": "Assurance policy summary",
        "responses": { "200": { "description": "Assurance summary" } }
      }
    },
    "/v1/diagnosis/summary": {
      "get": {
        "summary": "Diagnosis policy summary",
        "responses": { "200": { "description": "Diagnosis summary" } }
      }
    },
    "/v1/readiness/run": {
      "post": {
        "summary": "Run readiness checks with device pool impact",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Readiness report" } }
      }
    },
    "/v1/drift": {
      "get": {
        "summary": "Operational drift report",
        "parameters": [
          {
            "name": "baseline_id",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Drift rollup across 7 dimensions" } }
      }
    },
    "/v1/drift/scans": {
      "get": {
        "summary": "List recorded operational drift scans",
        "responses": { "200": { "description": "Scan history (scheduled and manual)" } }
      }
    },
    "/v1/drift/scan": {
      "post": {
        "summary": "Run operational drift scan and record result",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "baseline_id": { "type": "string", "description": "Defaults to latest snapshot or SPANDA_DRIFT_SCAN_BASELINE_ID" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Scan record with alert dispatch on failure" } }
      }
    },
    "/v1/ota/plan": {
      "post": {
        "summary": "Plan OTA rollout (canary, staged, blue_green)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "strategy": { "type": "string", "enum": ["all", "canary", "staged", "blue_green"] },
                  "version": { "type": "string" },
                  "canary_percent": { "type": "integer" },
                  "dry_run": { "type": "boolean" },
                  "rollback_on_readiness_fail": { "type": "boolean", "description": "Rollback agent when post-deploy readiness fails" },
                  "readiness_runtime": { "type": "boolean", "description": "Include runtime checks in post-deploy readiness gate" },
                  "assignments": { "type": "array", "items": { "type": "object" } }
                },
                "required": ["strategy", "version"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Rollout plan" } }
      }
    },
    "/v1/ota/execute": {
      "post": {
        "summary": "Execute OTA rollout against deploy agents (dry_run supported)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "strategy": { "type": "string", "enum": ["all", "canary", "staged", "blue_green"] },
                  "version": { "type": "string" },
                  "canary_percent": { "type": "integer" },
                  "dry_run": { "type": "boolean" },
                  "rollback_on_readiness_fail": { "type": "boolean", "description": "Rollback agent when post-deploy readiness fails" },
                  "readiness_runtime": { "type": "boolean", "description": "Include runtime checks in post-deploy readiness gate" },
                  "assignments": { "type": "array", "items": { "type": "object" } }
                },
                "required": ["strategy", "version"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Rollout result" } }
      }
    },
    "/v1/ota/status": {
      "get": {
        "summary": "Deploy state from .spanda/deploy-state.json",
        "responses": { "200": { "description": "OTA state" } }
      }
    },
    "/v1/trust/package": {
      "get": {
        "summary": "Package trust evaluation",
        "parameters": [
          { "name": "name", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "version", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Trust score report" } }
      }
    },
    "/v1/trust/program": {
      "get": {
        "summary": "Composite program trust evaluation (CLI parity)",
        "parameters": [
          { "name": "file", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Program trust report" } }
      }
    },
    "/v1/entities": {
      "get": {
        "summary": "Unified entity inventory (all platform objects)",
        "parameters": [
          { "name": "kind", "in": "query", "schema": { "type": "string" } },
          { "name": "health_status", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Entity list" } }
      }
    },
    "/v1/entities/graph": {
      "get": {
        "summary": "Full entity graph for traversal and visualization",
        "responses": { "200": { "description": "Entity graph" } }
      }
    },
    "/v1/entities/traceability": {
      "get": {
        "summary": "Unified entity, program, and digital-thread traceability",
        "parameters": [
          { "name": "entity_id", "in": "query", "schema": { "type": "string" } },
          { "name": "capability", "in": "query", "schema": { "type": "string" } },
          { "name": "device_id", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Traceability report" } }
      }
    },
    "/v1/entities/register": {
      "post": {
        "summary": "Register entity in mutation overlay",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Registered entity" } }
      }
    },
    "/v1/entities/relationships": {
      "post": {
        "summary": "Relate two entities in mutation overlay",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Relationship edge" } }
      }
    },
    "/v1/entities/sync": {
      "post": {
        "summary": "Sync mutation overlay entities to TOML fragments",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Sync result" } }
      }
    },
    "/v1/entities/query": {
      "post": {
        "summary": "Structured entity query",
        "responses": { "200": { "description": "Query result" } }
      }
    },
    "/v1/entities/{id}": {
      "get": {
        "summary": "Get entity by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Entity record" }, "404": { "description": "Not found" } }
      }
    },
    "/v1/entities/{id}/tags": {
      "post": {
        "summary": "Add or remove tags on an entity overlay record",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Updated entity tags" } }
      }
    },
    "/v1/entities/{id}/relationships": {
      "get": {
        "summary": "Relationship edges, impact analysis, dependency chain",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Entity relationships" } }
      }
    },
    "/v1/entities/{id}/health": {
      "get": {
        "summary": "Health status for any entity",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Entity health" } }
      }
    },
    "/v1/entities/{id}/readiness": {
      "get": {
        "summary": "Readiness status for any entity",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Entity readiness" } }
      }
    },
    "/v1/entities/{id}/trust": {
      "get": {
        "summary": "Trust and security metadata for an entity",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Entity trust" } }
      }
    },
    "/v1/programs/readiness": {
      "post": {
        "summary": "Evaluate program readiness (CLI parity)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string" },
                  "target": { "type": "string" },
                  "include_runtime": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Readiness report" } }
      }
    },
    "/v1/programs/assure": {
      "post": {
        "summary": "Mission assurance evaluation (CLI parity)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "file": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Assurance report" } }
      }
    },
    "/v1/programs/diagnose": {
      "post": {
        "summary": "Diagnose program or trace (CLI parity)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "file": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Diagnosis report" } }
      }
    },
    "/v1/programs/recovery/heal": {
      "post": {
        "summary": "Recovery evaluation (CLI parity)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "file": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Recovery report" } }
      }
    },
    "/v1/programs/verify/hardware": {
      "post": {
        "summary": "Hardware compatibility verification (CLI parity)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string" },
                  "target": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Hardware verification report" } }
      }
    },
    "/v1/programs/verify/capabilities": {
      "post": {
        "summary": "Capability verification (CLI parity)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string" },
                  "traceability": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Capability verification report" } }
      }
    },
    "/v1/programs/verify/mission": {
      "post": {
        "summary": "Mission verification (CLI parity)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "file": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Mission verification report" } }
      }
    },
    "/v1/programs/simulation": {
      "post": {
        "summary": "Simulation planning or driver execution (CLI parity)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string" },
                  "execute": { "type": "boolean", "default": false, "description": "Run driver when true" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Simulation result" } }
      }
    },
    "/v1/programs/replay": {
      "post": {
        "summary": "Inspect or replay a mission trace (CLI parity)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string" },
                  "deterministic": { "type": "boolean", "default": false },
                  "playback": { "type": "boolean", "default": false }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Replay result" } }
      }
    },
    "/v1/sre/summary": {
      "get": {
        "summary": "SRE availability and incident rollup",
        "responses": { "200": { "description": "SRE metrics" } }
      }
    },
    "/v1/sre/incidents": {
      "get": {
        "summary": "List operational incidents",
        "responses": { "200": { "description": "Incident list" } }
      },
      "post": {
        "summary": "Open an incident",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Incident created" } }
      }
    },
    "/v1/sre/incidents/{id}/ack": {
      "post": {
        "summary": "Acknowledge an incident",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Incident acknowledged" } }
      }
    },
    "/v1/sre/incidents/{id}/resolve": {
      "post": {
        "summary": "Resolve an incident",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Incident resolved" } }
      }
    },
    "/v1/integrations/pagerduty/webhook": {
      "post": {
        "summary": "PagerDuty inbound incident sync (acknowledge/resolve)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Incident synced" } }
      }
    },
    "/v1/observability/traces": {
      "get": {
        "summary": "Recent API trace records (OTLP-compatible export path)",
        "responses": { "200": { "description": "Trace log" } }
      }
    },
    "/v1/observability/backend": {
      "get": {
        "summary": "Configured OTLP collector endpoints (SPANDA_OTEL_COLLECTOR_URL)",
        "responses": { "200": { "description": "Observability backend summary" } }
      }
    },
    "/v1/observability/otlp/traces": {
      "get": {
        "summary": "OTLP/JSON trace preview for Jaeger",
        "responses": { "200": { "description": "resourceSpans payload" } }
      }
    },
    "/v1/observability/otlp/metrics": {
      "get": {
        "summary": "OTLP/JSON metrics preview",
        "responses": { "200": { "description": "resourceMetrics payload" } }
      }
    },
    "/v1/observability/otlp/export": {
      "post": {
        "summary": "Push API traces to OTLP collector",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
