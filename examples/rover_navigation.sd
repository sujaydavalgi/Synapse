module navigation;

import sensors.lidar;
import motion.drive;

struct NavPose {
  x: Distance;
  y: Distance;
  heading: Angle;
}

enum NavState {
  Idle,
  Cruising,
  Avoiding
}

trait PathPlanner {
  fn plan(goal: NavPose) -> Path;
}

robot Rover {
  sensor lidar: Lidar on "/scan";
  actuator wheels: DifferentialDrive;

  safety {
    max_speed = 1.0 m/s;
    stop_if lidar.nearest_distance < 0.5 m;
  }

  behavior navigate() {
      let state = "Cruising";

      loop every 100ms {
        let scan = lidar.read();

        match state {
          Idle => wheels.stop();
          Cruising => wheels.drive(linear: 0.5 m/s, angular: 0.0 rad/s);
          Avoiding => wheels.drive(linear: 0.0 m/s, angular: 0.4 rad/s);
        };

        if scan.nearest_distance < 1.0 m {
          wheels.drive(linear: 0.0 m/s, angular: 0.3 rad/s);
      }
    }
  }
}
