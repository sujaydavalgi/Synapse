// Feature: struct literals with typed fields
//
//   spanda check examples/features/struct_literals.sd
//   spanda run examples/features/struct_literals.sd

struct Waypoint {
  x: Distance;
  y: Distance;
  heading: Angle;
}

robot StructRover {
  actuator wheels: DifferentialDrive;

  behavior run() {
    let goal = Waypoint { x: 2.0 m, y: 1.0 m, heading: 0.25 rad };
    let _ = goal.x;
    wheels.stop();
  }
}
