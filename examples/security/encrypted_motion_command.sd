robot MotionBot {
  trust trusted;

  permissions [
    crypto.encrypt,
    crypto.sign,
    crypto.verify,
    identity.sign,
    identity.verify,
    secret.read,
    secure_topic.publish,
    actuator.execute.safe
  ];

  secrets {
    motion_key from env "MOTION_SESSION_KEY";
  }

  identity RoverIdentity {
    id: "motion-bot";
    public_key: "pub-motion";
  }

  trust_boundary robot_to_robot;

  topic motion_cmd: Topic<SafeAction> {
    secure {
      encryption required;
      signed required;
      trusted_sources [PlannerAgent];
      reject_untrusted true;
    }
  };

  agent PlannerAgent {
    uses planner;
    tools [];
    goal "Plan motion";
    can [ publish(motion_cmd), plan ];

    plan {
      publish motion_cmd with safe_action(type: "forward", speed: 0.2);
    }
  }

  ai_model planner: LLM { provider: "mock"; model: "test"; temperature: 0.1; }

  behavior run() {
    PlannerAgent.plan();
  }
}
